{
    "name": "token27/nexus-ai-agents",
    "description": "Autonomous AI agent framework — planning, reflection, memory, tools, and multi-agent coordination built on NexusAI Workflows. Framework-agnostic, PSR-only, PHP 8.2+.",
    "keywords": [
        "ai",
        "agent",
        "llm",
        "planning",
        "react",
        "chain-of-thought",
        "multi-agent",
        "memory",
        "nexus-ai",
        "php"
    ],
    "authors": [
        {
            "name": "Token27",
            "email": "dev@token27.com"
        }
    ],
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/token27/nexus-ai"
        },
        {
            "type": "vcs",
            "url": "https://github.com/token27/nexus-ai-workflows"
        }
    ],
    "require": {
        "php": "^8.3",
        "token27/nexus-ai": "^1.0",
        "token27/nexus-ai-workflows": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Token27\\NexusAI\\Agents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Token27\\NexusAI\\Agents\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "test": "phpunit",
        "test:unit": "phpunit tests/Unit/",
        "quality": [
            "@analyse",
            "@cs-check",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}